# Jira Configuration
# Copy this file to .env and fill in your credentials

# Jira Server URL (already set in script, but can be overridden)
JIRA_SERVER=https://your-jira-instance.example.com

# Your Jira credentials (for SSO environments, use API token)
JIRA_USERNAME=your_email@example.com
JIRA_API_TOKEN=your_api_token_here

# Optional: Default project settings
DEFAULT_PROJECT=ARTS
DEFAULT_ASSIGNEE=me